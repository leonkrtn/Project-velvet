# Supabase — Projekt unter https://supabase.com anlegen (EU-Region: Frankfurt)
# Diese Werte aus dem Supabase-Dashboard kopieren (Settings → API)

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Direkte Postgres-Verbindung für automatische Tabellen-Erstellung
# Supabase Dashboard → Settings → Database → Connection string → URI (Session Mode / Port 6543)
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[DB_PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# ─── Cloudflare R2 + Worker (Datei-Verwaltung) ─────────────────────────────
# Cloudflare Worker URL (nach `wrangler deploy` sichtbar, z.B. https://velvet-file-service.ACCOUNT.workers.dev)
# Für lokale Entwicklung: http://localhost:8787 (wrangler dev im workers/file-service/ Verzeichnis)
FILE_WORKER_URL=https://velvet-file-service.ACCOUNT.workers.dev

# Internes Shared Secret zwischen Next.js und Cloudflare Worker.
# Erzeugen: openssl rand -hex 32
# Muss als Wrangler Secret gesetzt werden: wrangler secret put INTERNAL_SECRET (im workers/file-service/)
FILE_WORKER_INTERNAL_SECRET=replace-with-openssl-rand-hex-32

# ─── Cloudflare Worker Secrets (NUR im Worker setzen, NICHT hier) ──────────
# Diese Werte gehören ausschließlich in den Cloudflare Worker (wrangler secret put):
#   INTERNAL_SECRET        → gleicher Wert wie FILE_WORKER_INTERNAL_SECRET oben
#   R2_ACCOUNT_ID          → Cloudflare Dashboard → oben rechts (Account ID)
#   R2_ACCESS_KEY_ID       → R2 → Manage R2 API Tokens → Token erstellen (Objekte lesen+schreiben)
#   R2_SECRET_ACCESS_KEY   → Secret Key des R2 API Tokens
#   R2_BUCKET_NAME         → velvet-files (Bucket-Name aus wrangler.toml)

# ─── Cloudflare R2 Bucket Setup ────────────────────────────────────────────
# 1. Cloudflare Dashboard → R2 → Bucket erstellen
#    Name: velvet-files
#    Location: Western Europe (WEUR) ← für DSGVO
#    Public access: OFF (niemals einschalten)
# 2. R2 → Manage R2 API Tokens → Token mit "Object Read & Write" erstellen
#    → Account ID, Access Key ID, Secret Access Key notieren
# 3. wrangler secret put INTERNAL_SECRET  (im workers/file-service/)
# 4. wrangler secret put R2_ACCOUNT_ID
# 5. wrangler secret put R2_ACCESS_KEY_ID
# 6. wrangler secret put R2_SECRET_ACCESS_KEY
# 7. wrangler secret put R2_BUCKET_NAME
# 8. wrangler deploy  → gibt die Worker-URL aus → in FILE_WORKER_URL eintragen
# 9. In Vercel: FILE_WORKER_URL + FILE_WORKER_INTERNAL_SECRET als Env Vars setzen

# ─── Einrichtung (komplett) ─────────────────────────────────────────────────
# 1. Supabase-Konto erstellen: https://supabase.com
# 2. Neues Projekt in Region "eu-central-1" (Frankfurt) anlegen
# 3. Obige Werte aus Settings → API kopieren
# 4. DATABASE_URL aus Settings → Database → Connection string (URI) kopieren
# 5. Diese Datei zu .env.local kopieren (nicht committen!)
# 6. Cloudflare R2 Bucket + Worker wie oben beschrieben einrichten

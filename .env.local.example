# Supabase — Projekt unter https://supabase.com anlegen (EU-Region: Frankfurt)
# Diese Werte aus dem Supabase-Dashboard kopieren (Settings → API)

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Direkte Postgres-Verbindung für automatische Tabellen-Erstellung
# Supabase Dashboard → Settings → Database → Connection string → URI (Session Mode / Port 6543)
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[DB_PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Einrichtung:
# 1. Supabase-Konto erstellen: https://supabase.com
# 2. Neues Projekt in Region "eu-central-1" (Frankfurt) anlegen
# 3. Obige Werte aus Settings → API kopieren
# 4. DATABASE_URL aus Settings → Database → Connection string (URI) kopieren
# 5. Diese Datei zu .env.local kopieren (nicht committen!)
# → Die App erstellt alle Tabellen beim ersten Start automatisch!
